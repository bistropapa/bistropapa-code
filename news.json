        queries=[
            '子育て OR 育児 OR 父親 OR パパ OR 家事育児 OR 共働き OR 食育 -逮捕 -炎上 -動物 -映画 -アニメ -芸能',
            '家族 OR 親子 OR 子ども OR 保育 OR 教育 OR パパ育児 OR 父親支援 -逮捕 -炎上 -動物 -映画 -アニメ -芸能'
        ],
        include_any=[
            "子育て", "育児", "父親", "パパ", "親子", "家族",
            "子ども", "教育", "保育", "食育", "共働き", "家事育児"
        ],
        exclude_any=[
