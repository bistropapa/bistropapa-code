def fetch_url(url: str, timeout: int = 20) -> bytes:
    req = urllib.request.Request(
        url,
        headers={
            "User-Agent": USER_AGENT,
            "Accept": "application/rss+xml, application/xml, text/xml;q=0.9, */*;q=0.8",
        },
    )
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return resp.read()


def build_google_news_rss_url(query: str) -> str:
    encoded = urllib.parse.quote(query, safe="")
    return (
        "https://news.google.com/rss/search"
        f"?q={encoded}"
        "&hl=ja&gl=JP&ceid=JP:ja"
    )


def clean_text(text: str) -> str:
    if not text:
        return ""
    text = re.sub(r"\s+", " ", text).strip()
    text = text.replace("\u3000", " ")
    return text


def parse_google_news_rss(xml_bytes: bytes) -> list[dict]:
    root = ET.fromstring(xml_bytes)
    items: list[dict] = []

    for item in root.findall(".//item"):
        title = clean_text(item.findtext("title", default=""))
        link = clean_text(item.findtext("link", default=""))
        pub_date_raw = clean_text(item.findtext("pubDate", default=""))
        source = clean_text(item.findtext("source", default=""))

        if not title or not link:
            continue

        published_at = ""
        if pub_date_raw:
            try:
                dt = parsedate_to_datetime(pub_date_raw)
                if dt.tzinfo is None:
                    dt = dt.replace(tzinfo=timezone.utc)
                published_at = dt.astimezone(timezone.utc).isoformat().replace("+00:00", "Z")
            except Exception:
                published_at = ""

        items.append({
            "title": title,
            "url": link,
            "source": source or extract_domain(link),
            "publishedAt": published_at,
        })

    return items


def extract_domain(url: str) -> str:
    try:
        return urllib.parse.urlparse(url).netloc.lower()
    except Exception:
        return ""


def normalize_for_dedup(text: str) -> str:
    text = text.lower()
    text = re.sub(r"[【】\[\]\(\)（）「」『』!！?？:：・/／\-—_.,、。]+", " ", text)
    text = re.sub(r"\s+", " ", text).strip()
    return text


def contains_any(text: str, words: Iterable[str]) -> bool:
    t = text.lower()
    return any(w.lower() in t for w in words)


def is_blocked_source(source: str, blocked_sources: list[str]) -> bool:
    s = source.lower().strip()
    return any(bs.lower() in s for bs in blocked_sources)


def is_blocked_domain(url: str, blocked_domains: list[str]) -> bool:
    domain = extract_domain(url)
    return any(bd.lower() in domain for bd in blocked_domains)


def is_relevant(item: dict, cfg: CategoryConfig) -> bool:
    title = item.get("title", "")
    source = item.get("source", "")
    url = item.get("url", "")

    joined = f"{title} {source}"

    if not title or not url:
        return False

    if contains_any(joined, cfg.exclude_any):
        return False

    if is_blocked_source(source, cfg.blocked_sources):
        return False

    if is_blocked_domain(url, cfg.blocked_domains):
        return False

    if not contains_any(joined, cfg.include_any):
        return False

    return True


def score_item(item: dict, cfg: CategoryConfig) -> int:
    text = f"{item.get('title', '')} {item.get('source', '')}"
    score = 0

    for word in cfg.include_any:
        if word.lower() in text.lower():
            score += 2

    # 信頼しやすい雰囲気のソースを少し加点
    preferred_sources = [
        "NHK", "朝日", "毎日", "読売", "日経", "ITmedia", "Impress", "CNET", "Yahoo",
        "教育新聞", "食品新聞", "農業協同組合", "PRTIMES"
    ]
    if contains_any(item.get("source", ""), preferred_sources):
        score += 1

    # タイトルの長すぎる告知系を少し減点
    if len(item.get("title", "")) > 60:
        score -= 1

    return score


def fetch_category_articles(cfg: CategoryConfig) -> list[dict]:
    collected: list[dict] = []
    seen_keys: set[str] = set()

    for query in cfg.queries:
        url = build_google_news_rss_url(query)

        try:
            xml_bytes = fetch_url(url)
            items = parse_google_news_rss(xml_bytes)
        except Exception as e:
            print(f"[WARN] RSS fetch failed for {cfg.label}: {query} -> {e}", file=sys.stderr)
            continue

        for item in items:
            if not is_relevant(item, cfg):
                continue

            dedup_key = normalize_for_dedup(item["title"])
            if dedup_key in seen_keys:
                continue

            seen_keys.add(dedup_key)
            item["label"] = cfg.label
            collected.append(item)

        # 念のため連続アクセスを少し避ける
        time.sleep(0.3)

    collected.sort(
        key=lambda x: (
            score_item(x, cfg),
            x.get("publishedAt", "")
        ),
        reverse=True,
    )

    return collected[: cfg.max_items]


def merge_and_sort(all_category_articles: list[list[dict]]) -> list[dict]:
    merged: list[dict] = []
    seen: set[tuple[str, str]] = set()

    for articles in all_category_articles:
        for item in articles:
            key = (
                item.get("label", ""),
                normalize_for_dedup(item.get("title", "")),
            )
            if key in seen:
                continue
            seen.add(key)
            merged.append(item)

    merged.sort(key=lambda x: x.get("publishedAt", ""), reverse=True)
    return merged


def build_output() -> dict:
    all_category_articles: list[list[dict]] = []

    for cfg in CATEGORY_CONFIGS:
        articles = fetch_category_articles(cfg)
        all_category_articles.append(articles)

    merged_articles = merge_and_sort(all_category_articles)

    updated = datetime.now(JST).strftime("%Y-%m-%d %H:%M JST")

    return {
        "updated": updated,
        "articles": merged_articles,
    }


def save_output(data: dict, output_file: Path) -> None:
    output_file.write_text(
        json.dumps(data, ensure_ascii=False, indent=2),
        encoding="utf-8"
    )


def main() -> int:
    try:
        data = build_output()
        save_output(data, OUTPUT_FILE)
        print(f"[OK] news.json updated: {len(data.get('articles', []))} articles")
        return 0
    except Exception as e:
        print(f"[ERROR] failed to build news.json: {e}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
