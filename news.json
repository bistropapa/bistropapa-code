    label: str
    queries: list[str]
    include_any: list[str]
    exclude_any: list[str]
    blocked_sources: list[str]
    blocked_domains: list[str]
    max_items: int = 5


CATEGORY_CONFIGS: list[CategoryConfig] = [
    CategoryConfig(
        label="料理・食",
